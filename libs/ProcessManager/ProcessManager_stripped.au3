If @error Or Not $aCall[0] Then Return SetError(@error + 10, @extended, 0)
Local $aRet[25]
For $i = 0 To 17
$aRet[$i] = DllStructGetData($tSPC, 1, $i + 1)
Next
$aRet[18] = DllStructGetData($tSPC, 3)
For $i = 19 To 20
$aRet[$i] = DllStructGetData($tSPC, 5, $i - 18)
Next
For $i = 21 To 24
$aRet[$i] = DllStructGetData($tSPC, 7, $i - 20)
Next
Return $aRet
EndFunc
