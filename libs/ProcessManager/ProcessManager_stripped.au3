Local $iLastError = _WinAPI_GetLastError()
If $aCall[2] = 0 Then Return SetError(10, $iLastError, 0)
If $iLastError Then Return SetError(11, $iLastError, 0)
EndIf
Return __WinAPI_MakeQWord($aCall[0], $aCall[2])
EndFunc
