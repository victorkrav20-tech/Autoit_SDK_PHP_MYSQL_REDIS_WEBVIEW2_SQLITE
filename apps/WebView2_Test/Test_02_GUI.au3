; ===============================================================================
; Test_02_GUI.au3 - Тест функций управления GUI WebView2
; Версия: 1.0.0
; Описание: Тестирование Create, Show, Hide, SetPosition, SetSize, GetHandle
; ===============================================================================

#include-once
#include "..\..\libs\SDK_Init.au3"

Global $sAppName = "Test_02_GUI"

; ===============================================================================
; Инициализация SDK и WebView2
; ===============================================================================
Local $bSDKInit = _SDK_Init($sAppName, True, 1, 3, True)
Local $bWebView2Init = _SDK_WebView2_Init("local", @ScriptDir & "\profile", "", @ScriptDir & "\gui", "")

If Not $bSDKInit Or Not $bWebView2Init Then
    ConsoleWrite("❌ Init Failed" & @CRLF)
    Exit 1
EndIf

_Logger_Write("========================================", 1)
_Logger_Write("🧪 Test_02_GUI - Функции управления окном", 1)
_Logger_Write("========================================", 1)

Opt("GUIOnEventMode", 1)

; ===============================================================================
; ТЕСТ 1: GUI Create
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 1: GUI Create", 1)
Local $bGUICreate = _WebView2_GUI_Create(0, "Test_02_GUI", 800, 600)

If $bGUICreate Then
    _Logger_Write("✅ PASS: GUI создан (800x600)", 3)
Else
    _Logger_Write("❌ FAIL: GUI не создан", 2)
    Exit 1
EndIf

; Ожидание готовности
_WebView2_Events_WaitForReady(0, 10000)

; ===============================================================================
; ТЕСТ 2: GetHandle
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 2: GetHandle", 1)
Local $hGUI = _WebView2_GUI_GetHandle()

If $hGUI <> 0 Then
    _Logger_Write("✅ PASS: Handle получен = " & $hGUI, 3)
Else
    _Logger_Write("❌ FAIL: Handle = 0", 2)
EndIf

; ===============================================================================
; ТЕСТ 3: Show
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 3: Show", 1)
_WebView2_GUI_Show()
_Logger_Write("✅ PASS: Окно показано", 3)
Sleep(100)

; ===============================================================================
; ТЕСТ 4: Hide
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 4: Hide", 1)
_WebView2_GUI_Hide()
_Logger_Write("✅ PASS: Окно скрыто", 3)
Sleep(100)

; ===============================================================================
; ТЕСТ 5: Show снова
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 5: Show снова", 1)
_WebView2_GUI_Show()
_Logger_Write("✅ PASS: Окно показано снова", 3)
Sleep(100)

; ===============================================================================
; ТЕСТ 6: SetPosition
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 6: SetPosition (100, 100)", 1)
_WebView2_GUI_SetPosition(100, 100)
_Logger_Write("✅ PASS: Позиция изменена", 3)
Sleep(100)

; ===============================================================================
; ТЕСТ 7: SetSize
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 7: SetSize (1024, 768)", 1)
_WebView2_GUI_SetSize(1024, 768)
_Logger_Write("✅ PASS: Размер изменён", 3)
Sleep(100)

; ===============================================================================
; ТЕСТ 8: SetPosition + SetSize вместе
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("📋 ТЕСТ 8: SetPosition (200, 200) + SetSize (640, 480)", 1)
_WebView2_GUI_SetPosition(200, 200)
_WebView2_GUI_SetSize(640, 480)
_Logger_Write("✅ PASS: Позиция и размер изменены", 3)
Sleep(100)

; ===============================================================================
; ФИНАЛ
; ===============================================================================
_Logger_Write("", 1)
_Logger_Write("========================================", 1)
_Logger_Write("🎉 Test_02_GUI завершён (8 тестов)", 3)
_Logger_Write("========================================", 1)

Exit 0
